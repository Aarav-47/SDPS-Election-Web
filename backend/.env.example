# Backend env (Azure App Service) — set these in
# Azure Portal → App Service → Configuration → Application settings.
# DO NOT commit real values (.env is gitignored).

# Cosmos DB for MongoDB connection string (Azure Portal → Cosmos DB → Connection strings → Primary)
# Append &retrywrites=false at the end — Cosmos requires it.
MONGO_URL=mongodb://<account>:<key>@<account>.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&maxIdleTimeMS=120000&appName=@<account>@

# Database name
DB_NAME=sdps-election

# Comma-separated list of allowed origins for CORS (no spaces around commas).
# Always include both your production Vercel URL and any preview URLs you want to allow.
CORS_ORIGINS=https://sdps-election-web.vercel.app,https://www.sdps-election-web.vercel.app

# JWT secret for admin tokens (use a long random string in production!)
JWT_SECRET=change-me-to-a-long-random-string
